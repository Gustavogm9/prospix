# ==============================================================================
# ProspIX — Variáveis de Ambiente para PRODUÇÃO
# ==============================================================================
# Copie este arquivo para .env.production e preencha todos os valores.
# NÃO commite o .env.production no repositório.
# ==============================================================================

NODE_ENV=production
PORT=3000

# --- URLs de Serviço ---
APP_URL=https://app.prospix.com.br
ADMIN_URL=https://admin.prospix.com.br
LANDING_URL=https://prospix.com.br
API_URL=https://api.prospix.com.br

# --- Banco de Dados ---
# Se usando PgBouncer (recomendado):
DATABASE_URL=postgresql://prospix:SUA_SENHA_FORTE@pgbouncer:6432/prospix?pgbouncer=true&connection_limit=10
# Se direto no PostgreSQL (dev/staging):
# DATABASE_URL=postgresql://prospix:SUA_SENHA_FORTE@postgres:5432/prospix
DATABASE_POOL_MIN=5
DATABASE_POOL_MAX=50

# --- Redis ---
# Produção: usar Redis gerenciado (Upstash, ElastiCache, etc)
REDIS_URL=redis://redis:6379
REDIS_MAX_RETRIES=10

# --- JWT (RS256) ---
# Gere com: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nSUA_CHAVE_PRIVADA\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nSUA_CHAVE_PUBLICA\n-----END PUBLIC KEY-----"
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=30d
MAGIC_LINK_TTL_SECONDS=600

# --- Criptografia de Secrets ---
# Gere com: openssl rand -hex 32
SECRETS_ENCRYPTION_KEY=SUA_CHAVE_DE_CRIPTOGRAFIA_32CHARS_MIN

# --- Evolution API (WhatsApp) ---
EVOLUTION_BASE_URL=https://evo.prospix.com.br
EVOLUTION_GUILDS_INSTANCE=guilds_master
EVOLUTION_GUILDS_API_KEY=SUA_API_KEY

# --- Convites ---
INVITATION_CODE_TTL_DAYS=14
INVITATION_CODE_PREFIX=PRSPX

# --- Google Calendar OAuth ---
GOOGLE_CLIENT_ID=SEU_GOOGLE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=SEU_GOOGLE_CLIENT_SECRET

# --- Asaas (Billing) ---
ASAAS_API_KEY=SUA_ASAAS_API_KEY
ASAAS_BASE_URL=https://api.asaas.com/v3
ASAAS_WEBHOOK_SECRET=SEU_WEBHOOK_SECRET

# --- Email (Resend) ---
RESEND_API_KEY=re_SUA_CHAVE_RESEND

# --- Cloudflare R2 (Storage) ---
R2_ACCOUNT_ID=SEU_ACCOUNT_ID
R2_ACCESS_KEY_ID=SEU_ACCESS_KEY
R2_SECRET_ACCESS_KEY=SEU_SECRET_KEY
R2_BUCKET=prospix
R2_PUBLIC_URL=https://storage.prospix.com.br

# --- Observabilidade (CRÍTICO para produção) ---
SENTRY_DSN=https://SEU_DSN@sentry.io/PROJETO
SLACK_ALERT_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../xxx

# --- Docker Compose Production ---
POSTGRES_USER=prospix
POSTGRES_PASSWORD=SUA_SENHA_FORTE_POSTGRES
POSTGRES_DB=prospix
