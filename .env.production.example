# ==============================================================================
# ProspIX — Variáveis de Ambiente para PRODUÇÃO (Vercel)
# ==============================================================================
# Configurar diretamente no Vercel Dashboard → Settings → Environment Variables.
# Este arquivo serve como referência das vars necessárias.
# ==============================================================================

NODE_ENV=production

# ── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://yvbyplzfqfrlfujathii.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=https://yvbyplzfqfrlfujathii.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── WhatsApp · Evolution API (Hostinger) ─────────────────────────────────────
EVOLUTION_BASE_URL=https://evo.prospix.com.br
EVOLUTION_GUILDS_INSTANCE=guilds_master
EVOLUTION_GUILDS_API_KEY=

# ── IA ───────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL_DEFAULT=gpt-4o-mini-2024-07-18
OPENAI_MODEL_CLASSIFIER=gpt-4o-mini-2024-07-18
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_FALLBACK=claude-3-5-haiku-20241022
GOOGLE_AI_API_KEY=
GOOGLE_AI_MODEL_FALLBACK=gemini-1.5-flash

# ── Google OAuth (Calendar) ──────────────────────────────────────────────────
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ── Secrets vault (AES-256-GCM) ──────────────────────────────────────────────
SECRETS_ENCRYPTION_KEY=

# ── Observabilidade ──────────────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=

# ── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_LOGIN_URL=/login
NEXT_PUBLIC_WEB_URL=https://www.prospix.com.br
NEXT_PUBLIC_DEMO_MODE=false
