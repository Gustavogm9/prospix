# =============================================================================
# Prospix · .env.example
# Copiar para .env e preencher. NUNCA commitar valores reais.
# =============================================================================

# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development

# ── Supabase (obrigatório · criar projeto em supabase.com/dashboard) ─────────
# Settings → API → Project URL, anon public, service_role
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── WhatsApp · Evolution API ─────────────────────────────────────────────────
# Servidor self-hosted (ex: evo.prospix.com.br na Hostinger)
# Config por tenant fica em tenant_secrets. Estas são as defaults.
EVOLUTION_BASE_URL=https://evo.prospix.com.br
EVOLUTION_GUILDS_INSTANCE=guilds_master
EVOLUTION_GUILDS_API_KEY=

# ── IA · OpenAI ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL_DEFAULT=gpt-4o-mini-2024-07-18
OPENAI_MODEL_CLASSIFIER=gpt-4o-mini-2024-07-18

# ── IA · Anthropic (fallback) ────────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_FALLBACK=claude-3-5-haiku-20241022

# ── IA · Google Gemini (fallback) ────────────────────────────────────────────
GOOGLE_AI_API_KEY=
GOOGLE_AI_MODEL_FALLBACK=gemini-1.5-flash

# ── Google OAuth (Calendar) ──────────────────────────────────────────────────
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ── Secrets vault (AES-256-GCM para criptografar tenant_secrets) ─────────────
# Gerar: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SECRETS_ENCRYPTION_KEY=

# ── Observabilidade ──────────────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=

# ── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_LOGIN_URL=/login
NEXT_PUBLIC_WEB_URL=http://localhost:3000
NEXT_PUBLIC_DEMO_MODE=false
