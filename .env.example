# =============================================================================
# Prospix · .env.example
# Copiar para .env.local e preencher. NUNCA commitar valores reais.
# =============================================================================

# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174
LANDING_URL=http://localhost:3001
API_URL=http://localhost:3000

# ── Database (Supabase Postgres em prod · local Docker em dev) ──────────────
DATABASE_URL=postgresql://prospix:prospix_dev@localhost:5432/prospix_dev?schema=public
SHADOW_DATABASE_URL=postgresql://prospix:prospix_dev@localhost:5432/prospix_dev_shadow?schema=public
DATABASE_POOL_MIN=5
DATABASE_POOL_MAX=50

# ── Supabase (produção · Realtime + Vault) ──────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Redis (Upstash em prod · local Docker em dev) ───────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_MAX_RETRIES=10

# ── Auth ─────────────────────────────────────────────────────────────────────
# Gerar par RSA: openssl genrsa -out jwt-private.pem 2048 && openssl rsa -in jwt-private.pem -pubout -out jwt-public.pem
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_EXPIRES_IN=30d
MAGIC_LINK_TTL_SECONDS=600

# ── Storage (Cloudflare R2 em prod) ──────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=prospix
R2_PUBLIC_URL=

# ── IA · OpenAI (chave Guilds compartilhada · default) ──────────────────────
OPENAI_API_KEY=
OPENAI_MODEL_DEFAULT=gpt-4o-mini-2024-07-18
OPENAI_MODEL_CLASSIFIER=gpt-4o-mini-2024-07-18

# ── IA · Anthropic (fallback) ────────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_FALLBACK=claude-3-5-haiku-20241022

# ── IA · Google Gemini (segundo fallback / opção tenant) ────────────────────
GOOGLE_AI_API_KEY=
GOOGLE_AI_MODEL_FALLBACK=gemini-1.5-flash

# ── WhatsApp · Evolution API (instância Guilds para magic links) ────────────
# A instância de cada tenant fica em tenant_secrets · esta é só do Guilds
EVOLUTION_BASE_URL=https://evo.prospix.com.br
EVOLUTION_GUILDS_INSTANCE=guilds_master
EVOLUTION_GUILDS_API_KEY=

# ── Google OAuth (Calendar) ──────────────────────────────────────────────────
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/v1/tenant/integrations/google/callback

# ── Secrets vault (AES-256-GCM) ──────────────────────────────────────────────
# Gerar: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SECRETS_ENCRYPTION_KEY=

# ── Billing · Asaas (MVP · PIX + boleto + cartão BR) ────────────────────────
ASAAS_API_KEY=
ASAAS_BASE_URL=https://api.asaas.com/v3
ASAAS_WEBHOOK_SECRET=

# ── Observabilidade ──────────────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_DSN_FRONTEND=

# ── Feature flags · GrowthBook (self-hosted) ────────────────────────────────
GROWTHBOOK_API_HOST=
GROWTHBOOK_CLIENT_KEY=

# ── Email · Resend ───────────────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM="Guilds <no-reply@guilds.com.br>"

# ── BrasilAPI (CNPJ enrichment) ─────────────────────────────────────────────
RECEITAWS_API_KEY=

# ── Limites globais ──────────────────────────────────────────────────────────
MAX_LEADS_PER_TENANT=50000
MAX_CAMPAIGNS_PER_TENANT=20
MAX_SCRIPTS_PER_TENANT=50

# ── Aquecimento WhatsApp ─────────────────────────────────────────────────────
WARMUP_DAY_1_LIMIT=5
WARMUP_DAY_15_LIMIT=70
WARMUP_REGIME_LIMIT=200

# ── LGPD / retenção ──────────────────────────────────────────────────────────
LEAD_ARCHIVE_AFTER_DAYS=180
TENANT_CHURNED_RETENTION_DAYS=90
EXPORT_DATA_URL_TTL_HOURS=168

# ── Invitation codes ─────────────────────────────────────────────────────────
INVITATION_CODE_TTL_DAYS=14
INVITATION_CODE_PREFIX=PRSPX
