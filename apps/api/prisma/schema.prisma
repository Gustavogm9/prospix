// =============================================================================
// Prospix · Schema Prisma (multi-tenant)
// =============================================================================
// Pronto pra copiar pra apps/api/prisma/schema.prisma
//
// Princípios:
// - Toda tabela de domínio tem tenant_id NOT NULL
// - RLS ativo em PostgreSQL (policies via migration · ver final do arquivo)
// - UNIQUE constraints consideram tenant_id
// - Soft delete via deleted_at (não DELETE direto)
// - Timestamps com timezone (timestamptz)
// =============================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions", "fullTextSearch"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgcrypto, pg_trgm]
}

// =============================================================================
// ENUMS
// =============================================================================

enum TenantStatus {
  ONBOARDING
  ACTIVE
  SUSPENDED
  CHURNING
  CHURNED
}

enum TenantPlan {
  STARTER
  STANDARD
  PREMIUM
}

enum UserRole {
  OWNER
  ASSISTANT
  GUILDS_ADMIN
}

enum AIProvider {
  GUILDS_SHARED
  TENANT_OWN
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum Profession {
  DOCTOR
  LAWYER
  DENTIST
  ENTREPRENEUR
  ENGINEER
  ARCHITECT
  ACCOUNTANT
  OTHER
}

enum LeadSource {
  GOOGLE_MAPS
  RECEITA_FEDERAL
  CRM_SP
  OAB_SP
  CRO_SP
  LINKEDIN
  REFERRAL
  LANDING_PAGE
  MANUAL
  IMPORTED
}

enum LeadStatus {
  CAPTURED
  ENRICHED
  CONTACTED
  NO_RESPONSE
  CONVERSING
  QUALIFIED
  MEETING_SCHEDULED
  CLOSED_WON
  CLOSED_LOST
  NOT_INTERESTED
  LOST_BEFORE_MEETING
  OPTED_OUT
  ARCHIVED
  ESCALATED_HUMAN
}

enum ConversationStatus {
  ACTIVE
  PAUSED
  ESCALATED
  CLOSED
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageSender {
  AI
  USER
  LEAD
}

enum MessageDeliveryStatus {
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
}

enum MeetingStatus {
  SCHEDULED
  CONFIRMED
  HAPPENED
  NO_SHOW
  RESCHEDULED
  CANCELLED
}

enum MeetingOutcome {
  CLOSED
  SECOND_MEETING
  NOT_INTERESTED
  THINKING
}

enum ScriptCategory {
  APPROACH
  OBJECTION
  EDUCATION
  CLOSING
  FOLLOW_UP
  REFERRAL
  REACTIVATION
}

enum ScriptStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum BillingStatus {
  PENDING
  PAID
  OVERDUE
  REFUNDED
  WAIVED
}

enum PromptType {
  SYSTEM
  CLASSIFIER
  GUARDRAIL_CORRECTIVE
  FOLLOW_UP
}

enum NotificationChannel {
  PUSH
  WHATSAPP
  EMAIL
  SMS
}

// =============================================================================
// TENANT (raiz)
// =============================================================================

model Tenant {
  id                 String       @id @default(uuid()) @db.Uuid
  slug               String       @unique @db.VarChar(64)
  name               String       @db.VarChar(255)
  status             TenantStatus
  plan               TenantPlan
  segment            String?      @db.VarChar(64) // 'insurance_metlife' | 'insurance_bradesco' | ...
  setupPaidCents     Int?         @map("setup_paid_cents")
  mrrCents           Int          @map("mrr_cents")
  contractSignedAt   DateTime?    @map("contract_signed_at") @db.Timestamptz()
  goLiveAt           DateTime?    @map("go_live_at") @db.Timestamptz()

  // Branding
  brandLogoUrl       String?      @map("brand_logo_url") @db.Text
  brandPrimaryColor  String?      @map("brand_primary_color") @db.VarChar(7)
  customDomain       String?      @unique @map("custom_domain") @db.VarChar(255) // white-label Fase 3

  // IA voice
  aiVoiceProfile     Json?        @map("ai_voice_profile")

  // Aquecimento WhatsApp (gateway-agnóstico · Evolution API)
  whatsappWarmupDay       Int       @default(1) @map("whatsapp_warmup_day")
  whatsappWarmupStartedAt DateTime? @map("whatsapp_warmup_started_at") @db.Timestamptz()

  // Áreas de alto valor (per-tenant, usado no fit score)
  highValueAreas     String[]     @map("high_value_areas")

  createdAt          DateTime     @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt          DateTime     @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt          DateTime?    @map("deleted_at") @db.Timestamptz()

  users              User[]
  secret             TenantSecret?
  aiConfig           TenantAIConfig?
  invitations        TenantInvitation[]
  campaigns          Campaign[]
  leads              Lead[]
  conversations      Conversation[]
  messages           Message[]
  meetings           Meeting[]
  scripts            Script[]
  scriptVariations   ScriptVariation[]
  leadEvents         LeadEvent[]
  optouts            Optout[]
  usage              TenantUsage[]
  billings           TenantBilling[]
  notifications      Notification[]
  auditLogs          AuditLog[]
  notes              LeadNote[]
  pendingOutbound    PendingOutbound[]
  tenantNotes        TenantNote[]
  lgpdRequests       LgpdRequest[]
  promptVersions     PromptVersion[]
  idempotencyKeys    IdempotencyKey[]
  discovery          TenantDiscovery?
  featureFlags       FeatureFlag[]
  alerts             OperationalAlert[]

  @@index([status])
  @@index([segment])
  @@map("tenants")
}

// =============================================================================
// TENANT SECRETS (vault · 1 row por tenant)
// =============================================================================

model TenantSecret {
  tenantId                       String     @id @map("tenant_id") @db.Uuid
  tenant                         Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // WhatsApp gateway · Evolution API (self-hosted Hostinger)
  evolutionBaseUrl               String?    @map("evolution_base_url") @db.Text       // ex: https://evo.prospix.com.br
  evolutionInstanceName          String?    @map("evolution_instance_name")            // ex: tenant_giovane
  evolutionApiKeyEncrypted       String?    @map("evolution_api_key_encrypted") @db.Text
  evolutionWebhookSecret         String?    @map("evolution_webhook_secret") @db.Text

  googleCalendarId               String?    @map("google_calendar_id")
  googleOauthRefreshEncrypted    String?    @map("google_oauth_refresh_encrypted") @db.Text
  googleOauthScope               String?    @map("google_oauth_scope") @db.Text

  googleMapsApiKeyEncrypted      String?    @map("google_maps_api_key_encrypted") @db.Text

  // API keys próprias do tenant (opcionais · senão usa Guilds-shared)
  openaiApiKeyEncrypted          String?    @map("openai_api_key_encrypted") @db.Text
  anthropicApiKeyEncrypted       String?    @map("anthropic_api_key_encrypted") @db.Text
  googleAiApiKeyEncrypted        String?    @map("google_ai_api_key_encrypted") @db.Text
  aiProvider                     AIProvider @default(GUILDS_SHARED) @map("ai_provider")

  // Telefonia (Fase 2)
  twilioAccountSidEncrypted      String?    @map("twilio_account_sid_encrypted") @db.Text
  twilioAuthTokenEncrypted       String?    @map("twilio_auth_token_encrypted") @db.Text

  updatedAt                      DateTime   @updatedAt @map("updated_at") @db.Timestamptz()

  @@map("tenant_secrets")
}

// =============================================================================
// TENANT AI CONFIG · modelo IA configurável por uso (system/classifier/guardrail)
// Permite trocar gpt-4o-mini ↔ claude-haiku ↔ gemini-flash sem deploy.
// =============================================================================

model TenantAIConfig {
  tenantId            String   @id @map("tenant_id") @db.Uuid
  tenant              Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Modelos por uso — null = usa default global Guilds
  systemProvider      String?  @map("system_provider") @db.VarChar(16)      // openai | anthropic | google
  systemModel         String?  @map("system_model") @db.VarChar(64)         // gpt-4o-mini | claude-3-5-haiku-20241022 | gemini-1.5-flash
  classifierProvider  String?  @map("classifier_provider") @db.VarChar(16)
  classifierModel     String?  @map("classifier_model") @db.VarChar(64)
  guardrailProvider   String?  @map("guardrail_provider") @db.VarChar(16)
  guardrailModel      String?  @map("guardrail_model") @db.VarChar(64)

  // Fallback chain · array ordenado de providers tentados em sequência
  fallbackChain       Json?    @map("fallback_chain")    // ex: ["openai", "anthropic", "google"]

  // Parâmetros LLM
  systemTemperature       Decimal  @default(0.4)  @map("system_temperature") @db.Decimal(3, 2)
  classifierTemperature   Decimal  @default(0.0)  @map("classifier_temperature") @db.Decimal(3, 2)
  maxOutputTokens         Int      @default(1024) @map("max_output_tokens")

  updatedAt           DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  @@map("tenant_ai_configs")
}

// =============================================================================
// TENANT INVITATION · código de convite gerado pelo super-admin Guilds
// Cadastro do owner é gated por código (setup pago off-platform)
// =============================================================================

model TenantInvitation {
  id            String    @id @default(uuid()) @db.Uuid
  code          String    @unique @db.VarChar(24)    // ex: PRSPX-A8K2-9F4M
  tenantId      String    @map("tenant_id") @db.Uuid
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  role          UserRole  @default(OWNER)
  createdById   String    @map("created_by_id") @db.Uuid    // guilds_admin que gerou
  expiresAt     DateTime  @map("expires_at") @db.Timestamptz()
  usedAt        DateTime? @map("used_at") @db.Timestamptz()
  usedByUserId  String?   @map("used_by_user_id") @db.Uuid
  revokedAt     DateTime? @map("revoked_at") @db.Timestamptz()
  notes         String?   @db.Text                   // notas internas do admin

  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  @@index([tenantId])
  @@index([code, usedAt, revokedAt])
  @@map("tenant_invitations")
}

// =============================================================================
// LGPD REQUESTS (AUD-P2-033 · solicitacoes do tenant ou de leads)
// Direitos do titular · LGPD art. 18
// =============================================================================

enum LgpdRequestType {
  EXPORT_DATA          // art. 18 V · portabilidade
  DELETE_TENANT_DATA   // art. 18 VI · exclusao do tenant inteiro
  DELETE_LEAD_DATA     // art. 18 VI · exclusao de um lead especifico
  CORRECT_DATA         // art. 18 III · correcao
  CONFIRM_DATA         // art. 18 I  · confirmacao da existencia
}

enum LgpdRequestStatus {
  PENDING              // criado · aguarda processamento Guilds
  PROCESSING           // operador Guilds esta executando
  COMPLETED            // resolvido · download disponivel se aplicavel
  REJECTED             // recusado · com motivo registrado
  CANCELED             // user cancelou
}

model LgpdRequest {
  id                String             @id @default(uuid()) @db.Uuid
  tenantId          String             @map("tenant_id") @db.Uuid
  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Quem solicitou
  requestedByUserId String?            @map("requested_by_user_id") @db.Uuid     // owner/assistant
  requestedByUser   User?              @relation("LgpdRequestedBy", fields: [requestedByUserId], references: [id])
  requestedByLead   String?            @map("requested_by_lead") @db.VarChar(24) // WhatsApp do lead quando vem via webhook

  type              LgpdRequestType
  status            LgpdRequestStatus  @default(PENDING)

  // Escopo (depende do tipo)
  // EXPORT_DATA: { include?: ["leads","conversations","meetings","scripts"] }
  // DELETE_LEAD_DATA: { lead_whatsapp: string }
  // CORRECT_DATA: { field: string, oldValue, newValue }
  scope             Json?

  // Output
  downloadUrl       String?            @map("download_url") @db.Text   // R2 presigned URL
  downloadExpiresAt DateTime?          @map("download_expires_at") @db.Timestamptz()
  rejectionReason   String?            @map("rejection_reason") @db.Text

  // Audit
  processedAt       DateTime?          @map("processed_at") @db.Timestamptz()
  processedById     String?            @map("processed_by_id") @db.Uuid     // guilds_admin que executou
  processedBy       User?              @relation("LgpdProcessedBy", fields: [processedById], references: [id])

  createdAt         DateTime           @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt         DateTime           @updatedAt @map("updated_at") @db.Timestamptz()

  @@index([tenantId, status])
  @@index([tenantId, createdAt(sort: Desc)])
  @@index([requestedByUserId])
  @@map("lgpd_requests")
}

// =============================================================================
// USER (per tenant · owner ou assistant + guilds_admin sem tenant)
// =============================================================================

model User {
  id                 String       @id @default(uuid()) @db.Uuid
  tenantId           String?      @map("tenant_id") @db.Uuid // null para guilds_admin
  tenant             Tenant?      @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  role               UserRole
  name               String       @db.VarChar(255)
  email              String       @unique @db.VarChar(255)
  whatsapp           String       @db.VarChar(20)

  susep              String?      @db.VarChar(64)
  partnerCode        String?      @map("partner_code") @db.VarChar(64)
  partnerBrand       String?      @map("partner_brand") @db.VarChar(64)

  city               String?      @db.VarChar(128)
  bio                String?      @db.Text
  avatarUrl          String?      @map("avatar_url") @db.Text
  passwordHash       String?      @map("password_hash") @db.Text

  // Preferências
  preferences        Json?

  lastLoginAt        DateTime?    @map("last_login_at") @db.Timestamptz()
  createdAt          DateTime     @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt          DateTime     @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt          DateTime?    @map("deleted_at") @db.Timestamptz()

  sessions           Session[]
  notificationPrefs  NotificationPreference[]
  notes              LeadNote[]
  notesTenant        TenantNote[]
  promptsCreated     PromptVersion[]
  auditLogs          AuditLog[]
  lgpdRequested      LgpdRequest[]            @relation("LgpdRequestedBy")
  lgpdProcessed      LgpdRequest[]            @relation("LgpdProcessedBy")
  discoveriesPm      TenantDiscovery[]        @relation("DiscoveryPm")
  alertsAcked        OperationalAlert[]       @relation("AlertAckBy")

  @@index([tenantId])
  @@index([email])
  @@map("users")
}

model Session {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshToken String   @unique @map("refresh_token") @db.Text
  expiresAt    DateTime @map("expires_at") @db.Timestamptz()
  revokedAt    DateTime? @map("revoked_at") @db.Timestamptz()
  ipAddress    String?  @map("ip_address") @db.Inet
  userAgent    String?  @map("user_agent") @db.Text
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@index([userId])
  @@index([refreshToken])
  @@map("sessions")
}

// =============================================================================
// CAMPAIGN (per tenant)
// =============================================================================

model Campaign {
  id              String         @id @default(uuid()) @db.Uuid
  tenantId        String         @map("tenant_id") @db.Uuid
  tenant          Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name            String         @db.VarChar(255)
  status          CampaignStatus @default(DRAFT)
  profession      Profession

  cities          String[]
  neighborhoods   String[]

  dailyLimit      Int            @default(100) @map("daily_limit")
  hourWindowStart Int            @default(9) @map("hour_window_start")  // 0-23
  hourWindowEnd   Int            @default(18) @map("hour_window_end")

  activeScriptId  String?        @map("active_script_id") @db.Uuid
  activeScript    Script?        @relation(fields: [activeScriptId], references: [id], onDelete: SetNull)

  filters         Json? // { age_min, cnpj_min_age, exclude_existing_clients, min_fit_score }

  // Estatísticas (denormalizadas, atualizadas via worker)
  totalCaptured   Int            @default(0) @map("total_captured")
  totalConversing Int            @default(0) @map("total_conversing")
  totalScheduled  Int            @default(0) @map("total_scheduled")
  totalClosedWon  Int            @default(0) @map("total_closed_won")

  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime       @updatedAt @map("updated_at") @db.Timestamptz()
  archivedAt      DateTime?      @map("archived_at") @db.Timestamptz()

  leads           Lead[]

  @@index([tenantId, status])
  @@map("campaigns")
}

// =============================================================================
// LEAD (per tenant)
// =============================================================================

model Lead {
  id                  String      @id @default(uuid()) @db.Uuid
  tenantId            String      @map("tenant_id") @db.Uuid
  tenant              Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  campaignId          String?     @map("campaign_id") @db.Uuid
  campaign            Campaign?   @relation(fields: [campaignId], references: [id])

  source              LeadSource
  sourceExternalId    String?     @map("source_external_id") @db.Text // place_id, cnpj
  sourceRawData       Json?       @map("source_raw_data")

  // Dados pessoais
  name                String?     @db.VarChar(255)
  profession          Profession?
  whatsapp            String      @db.VarChar(20)
  whatsappValid       Boolean?    @map("whatsapp_valid")
  email               String?     @db.VarChar(255)
  address             Json? // { city, neighborhood, street, lat, lng }
  ageEstimate         Int?        @map("age_estimate")

  // Profissional
  registrationNumber  String?     @map("registration_number") @db.VarChar(64) // CRM/OAB/CRO
  partnerOrOwner      Boolean?    @map("partner_or_owner")
  yearsOfPractice     Int?        @map("years_of_practice")
  googleRating        Decimal?    @map("google_rating") @db.Decimal(3, 2)
  googleReviewsCount  Int?        @map("google_reviews_count")

  // Score & status
  fitScore            Decimal?    @map("fit_score") @db.Decimal(3, 1) // 0.0 a 10.0
  status              LeadStatus  @default(CAPTURED)
  pipelineStage       String?     @map("pipeline_stage") @db.VarChar(64)

  // Metadata
  metadata            Json?
  tags                String[]

  // Timestamps de eventos
  contactedAt         DateTime?   @map("contacted_at") @db.Timestamptz()
  firstResponseAt     DateTime?   @map("first_response_at") @db.Timestamptz()
  qualifiedAt         DateTime?   @map("qualified_at") @db.Timestamptz()
  closedAt            DateTime?   @map("closed_at") @db.Timestamptz()

  createdAt           DateTime    @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt           DateTime    @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt           DateTime?   @map("deleted_at") @db.Timestamptz()

  conversations       Conversation[]
  meetings            Meeting[]
  events              LeadEvent[]
  notes               LeadNote[]
  healthProfile       HealthProfile?

  @@unique([tenantId, whatsapp])
  @@index([tenantId, status])
  @@index([tenantId, pipelineStage])
  @@index([tenantId, fitScore(sort: Desc)])
  @@index([tenantId, createdAt(sort: Desc)])
  @@index([campaignId])
  @@map("leads")
}

model LeadNote {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  leadId    String   @map("lead_id") @db.Uuid
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  authorId  String?  @map("author_id") @db.Uuid
  author    User?    @relation(fields: [authorId], references: [id])
  content   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@index([tenantId, leadId])
  @@map("lead_notes")
}

// Pré-qualificação saúde (Fase 2 · adicional 3.4)
model HealthProfile {
  leadId            String   @id @map("lead_id") @db.Uuid
  lead              Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  tenantId          String   @map("tenant_id") @db.Uuid

  smoker            Boolean?
  physicalActivity  String?  @map("physical_activity")
  weightKg          Decimal? @map("weight_kg") @db.Decimal(5, 2)
  heightCm          Int?     @map("height_cm")
  bmiCalculated     Decimal? @map("bmi_calculated") @db.Decimal(4, 2)
  preExistingDiseases String? @map("pre_existing_diseases")
  continuousMedication String? @map("continuous_medication")
  recentSurgery     Boolean? @map("recent_surgery")
  familyHistory     Json?    @map("family_history")

  riskCategory      String?  @map("risk_category") @db.VarChar(32)
  estimatedPremiumMinCents Int? @map("estimated_premium_min_cents")
  estimatedPremiumMaxCents Int? @map("estimated_premium_max_cents")

  collectedAt       DateTime @default(now()) @map("collected_at") @db.Timestamptz()
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  @@index([tenantId])
  @@map("health_profiles")
}

// =============================================================================
// CONVERSATION + MESSAGE
// =============================================================================

model Conversation {
  id               String             @id @default(uuid()) @db.Uuid
  tenantId         String             @map("tenant_id") @db.Uuid
  tenant           Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  leadId           String             @map("lead_id") @db.Uuid
  lead             Lead               @relation(fields: [leadId], references: [id], onDelete: Cascade)

  status           ConversationStatus @default(ACTIVE)
  aiHandling       Boolean            @default(true) @map("ai_handling")

  scriptId         String?            @map("script_id") @db.Uuid
  script           Script?            @relation(fields: [scriptId], references: [id], onDelete: SetNull)
  currentNodeId   String?             @map("current_node_id") @db.VarChar(64)

  messageCount     Int                @default(0) @map("message_count")
  lastMessageAt    DateTime?          @map("last_message_at") @db.Timestamptz()
  lastInboundAt    DateTime?          @map("last_inbound_at") @db.Timestamptz()
  lastOutboundAt   DateTime?          @map("last_outbound_at") @db.Timestamptz()
  escalatedReason  String?            @map("escalated_reason") @db.VarChar(64)

  startedAt        DateTime           @default(now()) @map("started_at") @db.Timestamptz()
  closedAt         DateTime?          @map("closed_at") @db.Timestamptz()

  messages         Message[]
  meetings         Meeting[]

  @@index([tenantId, status])
  @@index([tenantId, lastMessageAt(sort: Desc)])
  @@index([leadId])
  @@map("conversations")
}

model Message {
  id                  String                @id @default(uuid()) @db.Uuid
  tenantId            String                @map("tenant_id") @db.Uuid
  tenant              Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversationId      String                @map("conversation_id") @db.Uuid
  conversation        Conversation          @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  direction           MessageDirection
  sender              MessageSender
  content             String                @db.Text

  // WhatsApp tracking
  whatsappMessageId   String?               @unique @map("whatsapp_message_id") @db.VarChar(128)
  deliveryStatus      MessageDeliveryStatus? @map("delivery_status")
  deliveredAt         DateTime?             @map("delivered_at") @db.Timestamptz()
  readAt              DateTime?             @map("read_at") @db.Timestamptz()
  failedReason        String?               @map("failed_reason") @db.Text

  // IA cost tracking
  llmModel            String?               @map("llm_model") @db.VarChar(64)
  llmTokensInput      Int?                  @map("llm_tokens_input")
  llmTokensOutput     Int?                  @map("llm_tokens_output")
  llmCostCents        Int?                  @map("llm_cost_cents")
  llmLatencyMs        Int?                  @map("llm_latency_ms")

  // Script tracking
  scriptId            String?               @map("script_id") @db.Uuid
  scriptVariationId   String?               @map("script_variation_id") @db.Uuid
  scriptNodeId        String?               @map("script_node_id") @db.VarChar(64)
  intentDetected      String?               @map("intent_detected") @db.VarChar(64)
  intentConfidence    Decimal?              @map("intent_confidence") @db.Decimal(3, 2)

  createdAt           DateTime              @default(now()) @map("created_at") @db.Timestamptz()

  @@index([tenantId, conversationId, createdAt])
  @@index([whatsappMessageId])
  @@map("messages")
}

// Fila de mensagens agendadas (off-hours queue)
model PendingOutbound {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversationId  String   @map("conversation_id") @db.Uuid
  content         String   @db.Text
  scheduledFor    DateTime @map("scheduled_for") @db.Timestamptz()
  idempotencyKey  String   @unique @map("idempotency_key") @db.VarChar(128)
  sentAt          DateTime? @map("sent_at") @db.Timestamptz()
  failedAt        DateTime? @map("failed_at") @db.Timestamptz()
  failedReason    String?  @map("failed_reason") @db.Text
  attempts        Int      @default(0)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@index([scheduledFor, sentAt])
  @@index([tenantId])
  @@map("pending_outbound")
}

// =============================================================================
// MEETING
// =============================================================================

model Meeting {
  id                  String          @id @default(uuid()) @db.Uuid
  tenantId            String          @map("tenant_id") @db.Uuid
  tenant              Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  leadId              String          @map("lead_id") @db.Uuid
  lead                Lead            @relation(fields: [leadId], references: [id], onDelete: Cascade)
  conversationId      String?         @map("conversation_id") @db.Uuid
  conversation        Conversation?   @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  googleEventId       String?         @unique @map("google_event_id") @db.VarChar(128)
  scheduledFor        DateTime        @map("scheduled_for") @db.Timestamptz()
  durationMinutes     Int             @default(30) @map("duration_minutes")
  location            String?         @db.Text
  attendees           Json? // [{name, role, email?}]

  status              MeetingStatus   @default(SCHEDULED)
  outcome             MeetingOutcome?

  policyValueCents    Int?            @map("policy_value_cents")
  commissionCents     Int?            @map("commission_cents")

  notes               String?         @db.Text
  referralsCollected  Json?           @map("referrals_collected") // [{name, whatsapp}]
  referralsCount      Int             @default(0) @map("referrals_count")

  rescheduledFromId   String?         @map("rescheduled_from_id") @db.Uuid
  rescheduledFrom     Meeting?        @relation("Reschedule", fields: [rescheduledFromId], references: [id])
  reschedules         Meeting[]       @relation("Reschedule")

  createdAt           DateTime        @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt           DateTime        @updatedAt @map("updated_at") @db.Timestamptz()
  outcomeMarkedAt     DateTime?       @map("outcome_marked_at") @db.Timestamptz()

  @@index([tenantId, scheduledFor])
  @@index([tenantId, status])
  @@index([leadId])
  @@map("meetings")
}

// =============================================================================
// SCRIPTS (per tenant)
// =============================================================================

model Script {
  id                       String           @id @default(uuid()) @db.Uuid
  tenantId                 String           @map("tenant_id") @db.Uuid
  tenant                   Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  clonedFromTemplateId     String?          @map("cloned_from_template_id") @db.Uuid
  clonedFromTemplate       ScriptTemplate?  @relation(fields: [clonedFromTemplateId], references: [id])

  name                     String           @db.VarChar(255)
  category                 ScriptCategory
  targetProfession         Profession?      @map("target_profession")
  status                   ScriptStatus     @default(DRAFT)

  flow                     Json? // estrutura completa do flow
  baseMessage              String?          @map("base_message") @db.Text
  variables                String[]

  // Stats (denormalizadas)
  responseRate             Decimal?         @map("response_rate") @db.Decimal(5, 4)
  conversionRate           Decimal?         @map("conversion_rate") @db.Decimal(5, 4)
  totalUsages              Int              @default(0) @map("total_usages")

  createdAt                DateTime         @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt                DateTime         @updatedAt @map("updated_at") @db.Timestamptz()
  archivedAt               DateTime?        @map("archived_at") @db.Timestamptz()

  campaigns                Campaign[]
  conversations            Conversation[]
  variations               ScriptVariation[]

  @@index([tenantId, status, category])
  @@map("scripts")
}

model ScriptVariation {
  id                 String   @id @default(uuid()) @db.Uuid
  tenantId           String   @map("tenant_id") @db.Uuid
  tenant             Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  scriptId           String   @map("script_id") @db.Uuid
  script             Script   @relation(fields: [scriptId], references: [id], onDelete: Cascade)

  variantLetter      String   @map("variant_letter") @db.VarChar(2)
  message            String   @db.Text
  weight             Decimal  @default(0.33) @db.Decimal(3, 2)

  // Stats
  totalSent          Int      @default(0) @map("total_sent")
  totalResponded     Int      @default(0) @map("total_responded")
  totalConverted     Int      @default(0) @map("total_converted")
  responseRate       Decimal? @map("response_rate") @db.Decimal(5, 4)
  conversionRate     Decimal? @map("conversion_rate") @db.Decimal(5, 4)

  active             Boolean  @default(true)
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt          DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  @@unique([scriptId, variantLetter])
  @@index([tenantId])
  @@map("script_variations")
}

// =============================================================================
// SCRIPT TEMPLATES (master library · Guilds-owned · sem tenant_id)
// =============================================================================

model ScriptTemplate {
