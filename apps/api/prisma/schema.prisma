// =============================================================================
// USAGE & BILLING
// =============================================================================

model TenantUsage {
  id                    BigInt   @id @default(autoincrement())
  tenantId              String   @map("tenant_id") @db.Uuid
  tenant                Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  periodMonth           DateTime @map("period_month") @db.Date // primeiro dia do mês

  llmTokensInput        BigInt   @default(0) @map("llm_tokens_input")
  llmTokensOutput       BigInt   @default(0) @map("llm_tokens_output")
