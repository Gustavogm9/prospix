  invoiceUrl   String?       @map("invoice_url") @db.Text
  paymentMethod String?      @map("payment_method") @db.VarChar(32) // pix | boleto | credit_card

  externalInvoiceId String?  @map("external_invoice_id") @db.VarChar(128) // Stripe/Asaas

  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime      @updatedAt @map("updated_at") @db.Timestamptz()

  @@unique([tenantId, periodMonth])
  @@index([tenantId, status])
  @@index([status, dueAt])
  @@map("tenant_billing")
