// =============================================================================
// PROMPT VERSIONS (versionamento de prompts da IA)
// =============================================================================

model PromptVersion {
  id              String     @id @default(uuid()) @db.Uuid
  tenantId        String?    @map("tenant_id") @db.Uuid // null = global Guilds
  tenant          Tenant?    @relation(fields: [tenantId], references: [id])
  createdById     String?    @map("created_by_id") @db.Uuid
  createdBy       User?      @relation(fields: [createdById], references: [id])

  promptType      PromptType @map("prompt_type")
  version         Int        @default(1)
  template        String     @db.Text
  variablesRequired Json?    @map("variables_required")
  testCases       Json?      @map("test_cases")

  isActive        Boolean    @default(false) @map("is_active")
  notes           String?    @db.Text

  createdAt       DateTime   @default(now()) @map("created_at") @db.Timestamptz()
  activatedAt     DateTime?  @map("activated_at") @db.Timestamptz()
  deprecatedAt    DateTime?  @map("deprecated_at") @db.Timestamptz()

  // Apenas 1 ativo por (tenant_id, prompt_type) — enforce via partial unique index na migration
  @@index([tenantId, promptType, isActive])
  @@map("prompt_versions")
}

// =============================================================================
// IDEMPOTENCY KEYS
// =============================================================================

model IdempotencyKey {
  key            String   @id @db.VarChar(128)
  tenantId       String?  @map("tenant_id") @db.Uuid
  tenant         Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  endpoint       String   @db.VarChar(255)
  responseCache  Json?    @map("response_cache")
  statusCode     Int?     @map("status_code")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz()
  expiresAt      DateTime @map("expires_at") @db.Timestamptz()

  @@index([expiresAt])
  @@map("idempotency_keys")
}

// =============================================================================
// TENANT NOTES (super-admin Guilds anota sobre o tenant)
// =============================================================================

model TenantNote {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  authorId  String?  @map("author_id") @db.Uuid
  author    User?    @relation(fields: [authorId], references: [id])
  content   String   @db.Text
  category  String?  @db.VarChar(64) // 'support' | 'sales' | 'incident'
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@index([tenantId, createdAt(sort: Desc)])
  @@map("tenant_notes")
}

// =============================================================================
// FEATURE FLAGS · kill switches por tenant ou globais
// tenantId NULL = flag global · setado = override por tenant (override > global)
// Consultas via isFeatureEnabled(key, tenantId?) em src/lib/feature-flags.ts
// =============================================================================
model FeatureFlag {
  id           String   @id @default(uuid()) @db.Uuid
  key          String   @db.VarChar(120)
  tenantId     String?  @map("tenant_id") @db.Uuid
  tenant       Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  enabled      Boolean
  reason       String?  @db.Text
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  @@unique([key, tenantId])
  @@index([key])
  @@index([tenantId])
  @@map("feature_flags")
}

// =============================================================================
// OPERATIONAL ALERTS · alertas proativos para ops center
// type: 'billing.overdue' | 'lgpd.sla_near' | 'lgpd.sla_expired' | 'churn.critical' | 'dlq.accumulation' | ...
// severity: INFO | WARNING | CRITICAL
// =============================================================================
model OperationalAlert {
  id           String          @id @default(uuid()) @db.Uuid
  type         String          @db.VarChar(120)
  severity     AlertSeverity   @default(WARNING)
  tenantId     String?         @map("tenant_id") @db.Uuid
  tenant       Tenant?         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title        String          @db.VarChar(255)
  message      String          @db.Text
  context      Json?
  dedupKey     String?         @map("dedup_key") @db.VarChar(255) // evita duplicar alerta enquanto ativo
  ackById      String?         @map("ack_by_id") @db.Uuid
  ackBy        User?           @relation("AlertAckBy", fields: [ackById], references: [id])
  ackAt        DateTime?       @map("ack_at") @db.Timestamptz()
  resolvedAt   DateTime?       @map("resolved_at") @db.Timestamptz()
  createdAt    DateTime        @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime        @updatedAt @map("updated_at") @db.Timestamptz()

  @@unique([dedupKey])
  @@index([severity, resolvedAt])
  @@index([tenantId, createdAt(sort: Desc)])
  @@index([type])
  @@map("operational_alerts")
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

// =============================================================================
// TENANT DISCOVERY (Frente G · onboarding manual rastreável · 1 row por tenant)
// Roadmap completo: docs/agents/frente-g-discovery-onboarding.md
// =============================================================================
model TenantDiscovery {
  tenantId            String           @id @map("tenant_id") @db.Uuid
  tenant              Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  status              DiscoveryStatus  @default(NOT_STARTED)

  scheduledFor        DateTime?        @map("scheduled_for") @db.Timestamptz()
  conductedAt         DateTime?        @map("conducted_at") @db.Timestamptz()

  // Materiais (R2 keys · upload via endpoint dedicado · TODO L1 fase 2)
  audioR2Key          String?          @map("audio_r2_key") @db.Text
  videoR2Key          String?          @map("video_r2_key") @db.Text
  transcriptR2Key     String?          @map("transcript_r2_key") @db.Text
  attachments         Json?            // [{ r2_key, kind, label, uploaded_at }]

  // Drafts editáveis (TODO L1 fase 2 · editor JSON com schema validation)
  voiceProfileDraft   Json?            @map("voice_profile_draft")
  scriptsDraft        Json?            @map("scripts_draft")

  // Validação · max 2 rodadas
  validatedAt         DateTime?        @map("validated_at") @db.Timestamptz()
  validationRounds    Int              @default(0) @map("validation_rounds")

  // Aprovação formal
  approvedAt          DateTime?        @map("approved_at") @db.Timestamptz()
  approvalProofR2Key  String?          @map("approval_proof_r2_key") @db.Text

  pmUserId            String?          @map("pm_user_id") @db.Uuid
  pmUser              User?            @relation("DiscoveryPm", fields: [pmUserId], references: [id])

  notes               String?          @db.Text

  createdAt           DateTime         @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt           DateTime         @updatedAt @map("updated_at") @db.Timestamptz()

  @@index([status])
  @@map("tenant_discoveries")
}

enum DiscoveryStatus {
  NOT_STARTED
  SCHEDULED
  IN_SESSION
  CONSOLIDATING
  VALIDATING
  APPROVED
  CHURNED_BEFORE_APPROVAL
}

// =============================================================================
// MIGRATION SQL (rodar após `prisma migrate`):
// =============================================================================
//
// -- Ativar RLS em todas as tabelas de domínio
// ALTER TABLE users               ENABLE ROW LEVEL SECURITY;
// ALTER TABLE campaigns           ENABLE ROW LEVEL SECURITY;
// ALTER TABLE leads               ENABLE ROW LEVEL SECURITY;
// ALTER TABLE lead_notes          ENABLE ROW LEVEL SECURITY;
// ALTER TABLE health_profiles     ENABLE ROW LEVEL SECURITY;
// ALTER TABLE conversations       ENABLE ROW LEVEL SECURITY;
// ALTER TABLE messages            ENABLE ROW LEVEL SECURITY;
// ALTER TABLE pending_outbound    ENABLE ROW LEVEL SECURITY;
// ALTER TABLE meetings            ENABLE ROW LEVEL SECURITY;
// ALTER TABLE scripts             ENABLE ROW LEVEL SECURITY;
// ALTER TABLE script_variations   ENABLE ROW LEVEL SECURITY;
// ALTER TABLE lead_events         ENABLE ROW LEVEL SECURITY;
// ALTER TABLE optouts             ENABLE ROW LEVEL SECURITY;
// ALTER TABLE tenant_usage        ENABLE ROW LEVEL SECURITY;
// ALTER TABLE tenant_billing      ENABLE ROW LEVEL SECURITY;
// ALTER TABLE notifications       ENABLE ROW LEVEL SECURITY;
// ALTER TABLE tenant_notes        ENABLE ROW LEVEL SECURITY;
// ALTER TABLE tenant_secrets      ENABLE ROW LEVEL SECURITY;
// ALTER TABLE tenant_ai_configs   ENABLE ROW LEVEL SECURITY;
// ALTER TABLE tenant_invitations  ENABLE ROW LEVEL SECURITY;
//
// -- Policy padrão · só vê linhas do tenant atual
// CREATE POLICY tenant_isolation_leads ON leads
//   FOR ALL
//   USING (tenant_id::text = current_setting('app.tenant_id', true));
//
// -- Repetir igual para cada tabela (ou usar gerador):
// CREATE POLICY tenant_isolation_messages ON messages
//   FOR ALL
//   USING (tenant_id::text = current_setting('app.tenant_id', true));
// -- ... etc
//
// -- Role super-admin Guilds (bypassa RLS)
// CREATE ROLE guilds_admin BYPASSRLS;
//
// -- Partial unique index pra garantir 1 prompt ativo por (tenant, type)
// CREATE UNIQUE INDEX one_active_prompt_per_type
//   ON prompt_versions (tenant_id, prompt_type)
//   WHERE is_active = true;
//
// -- Audit log do PostgreSQL (extensão)
// CREATE EXTENSION IF NOT EXISTS pgaudit;
// ALTER SYSTEM SET pgaudit.log = 'write,ddl';
// =============================================================================
