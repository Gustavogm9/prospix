{
  "name": "@prospix/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --project tsconfig.build.json --noEmit && tsup src/index.ts src/workers/index.ts --format esm --target node20 --out-dir dist",
    "start": "node dist/index.js",
    "start:worker": "node dist/workers/index.js",
    "lint": "eslint src --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:multi-tenant": "vitest run tests/multi-tenant",
    "test:e2e": "playwright test",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy && tsx prisma/apply-rls.ts",
    "db:migrate:dev": "prisma migrate dev && tsx prisma/apply-rls.ts",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset --force && pnpm db:seed",
    "worker": "tsx watch src/workers/index.ts",
    "clean": "rm -rf dist .turbo node_modules/.cache"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^12.0.1",
    "@fastify/jwt": "^9.0.1",
    "@fastify/rate-limit": "^10.2.1",
    "@fastify/sensible": "^6.0.1",
    "@google/generative-ai": "^0.21.0",
    "@prisma/client": "^5.22.0",
    "@prospix/shared-types": "workspace:*",
    "dotenv": "^16.4.7",
    "bullmq": "^5.28.1",
    "dayjs": "^1.11.13",
    "fastify": "^5.1.0",
    "ioredis": "^5.4.1",
    "openai": "^4.73.1",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@prospix/mocks": "workspace:*",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^2.1.8",
    "msw": "^2.6.6",
    "playwright": "^1.49.0",
    "prisma": "^5.22.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
