{
  "cleanUrls": true,
  "routes": [
    {
      "src": "^/assets/(.*)$",
      "headers": { "cache-control": "public, max-age=31536000, immutable" },
      "dest": "/assets/$1"
    },
    {
      "src": "^/((?!assets/|favicon\\.ico|favicon\\.png|apple-touch-icon\\.png|manifest\\.json|pwa-192\\.png|pwa-512\\.png|sw\\.js).*)",
      "dest": "/index"
    }
  ]
}
