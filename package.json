{
  "name": "prospix",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Plataforma multi-tenant de prospecção inteligente via WhatsApp",
  "author": "Guilds",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:seed": "tsx supabase/seed.ts",
    "test": "pnpm --filter @prospix/shared-types test",
    "test:e2e": "turbo run test:e2e",
    "test:e2e:smoke": "playwright test",
    "test:e2e:smoke:install": "playwright install --with-deps chromium",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "1.60.0",
    "@supabase/supabase-js": "^2.106.2",
    "@types/node": "^22.10.0",
    "dotenv": "^16.4.7",
    "eslint": "^9.16.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.8.1",
    "tsx": "^4.19.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.60.0"
  },
  "pnpm": {
    "overrides": {
      "postcss@<8.5.10": ">=8.5.10",
      "form-data@>=4.0.0 <4.0.6": ">=4.0.6",
      "vite@<=6.4.2": "6.4.3",
      "minimatch@3.1.5>brace-expansion": "1.1.16",
      "minimatch@5.1.9>brace-expansion": "2.1.2",
      "minimatch@9.0.9>brace-expansion": "2.1.2",
      "minimatch@10.2.5>brace-expansion": "5.0.8",
      "js-yaml@>=4.0.0 <4.3.0": "4.3.0",
      "sharp@<0.35.0": ">=0.35.0"
    }
  }
}
